# Slack Incoming Webhook URL used by api/contact.js to relay Contact form
# submissions. Set the real value in Vercel: Project Settings → Environment
# Variables → SLACK_WEBHOOK_URL. Never commit the real value to git.
SLACK_WEBHOOK_URL=

# Optional: post video-share notifications (api/upload-notify.js) to a
# different Slack channel/webhook than SLACK_WEBHOOK_URL. If unset, video
# notifications fall back to SLACK_WEBHOOK_URL above.
SLACK_VIDEO_WEBHOOK_URL=

# Google service account used by api/upload-init.js, api/upload-chunk.js,
# and api/upload-notify.js to upload player videos to Google Drive
# (Google Cloud Console → IAM & Admin → Service Accounts → Keys → Create
# new key → JSON). Share GOOGLE_DRIVE_FOLDER_ID with this service account's
# email as an Editor so it can create subfolders and files inside it.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the JSON key's "private_key" value. Keep the literal \n sequences —
# the code un-escapes them at runtime — and wrap the whole value in quotes
# when pasting into Vercel's environment variable UI.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# The Drive folder's ID only (the segment after /folders/ in its URL, before
# any ?usp=... query string) — not the full drive.google.com link.
GOOGLE_DRIVE_FOLDER_ID=

# Password gate for the internal Shorts upload tool (/upload.html,
# api/upload-auth.js). Pick any shared password for the team.
UPLOAD_PAGE_PASSWORD=
# Random secret used to sign the upload_session cookie — unrelated to the
# password above, so rotating one doesn't affect the other. Generate with:
# openssl rand -hex 32
UPLOAD_SESSION_SECRET=

# TikTok for Developers app credentials (Content Posting API / Direct Post),
# used for the TikTok half of the Shorts multi-upload tool. From the app's
# page at developers.tiktok.com → Manage apps → Code Builder Shorts Uploader.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google OAuth client (Web application type) used for the YouTube half of
# the Shorts multi-upload tool — a service account can't upload to a
# channel, so this drives a one-time user consent instead. From Google Cloud
# Console → APIs & Services → Credentials → OAuth client ID.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Obtained once by the channel owner via /api/youtube-oauth-start (after
# logging into /upload.html), which redirects through Google consent and
# back to /api/youtube-oauth-callback, which displays this value once.
YOUTUBE_REFRESH_TOKEN=
